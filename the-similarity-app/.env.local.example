# the-similarity-app environment variables
#
# Copy this file to .env.local and edit as needed. Next.js picks up
# NEXT_PUBLIC_* vars at build time and inlines them into the client
# bundle, so changes require a rebuild (not a restart).

# Feed mode for the root workstation status bar.
# Values: "live" | "demo". Defaults to "demo" when unset.
# The status bar renders "feed live" or "feed demo" accordingly.
# Set to "live" once this deployment is wired to a real market feed.
NEXT_PUBLIC_DATA_MODE=demo

# Whether to show the 5 preview surfaces on the root shell.
# Values: "true" | "false". Defaults to "false" when unset.
# When false: only the Retrieve workstation renders, only `g r`
# works as a jump chord, and the command palette only navigates
# to retrieve. Clients never see inert mocks.
# When true: the full 6-verb layout (Retrieve / Represent / Simulate
# / Evaluate / Render / Decide) is preserved for internal preview.
NEXT_PUBLIC_SHOW_PREVIEW_SURFACES=false
