//@version=6
strategy("The Similarity Strategy", overlay = true, pyramiding = 0, max_bars_back = 5000, initial_capital = 100000, default_qty_type = strategy.percent_of_equity, default_qty_value = 10)

patternLength = input.int(40, "Pattern Length", minval = 20, maxval = 120)
forecastBars = input.int(20, "Forecast Bars", minval = 5, maxval = 60)
searchLookback = input.int(600, "Search Lookback", minval = 200, maxval = 3000)
searchStride = input.int(6, "Search Stride", minval = 1, maxval = 15, tooltip = "Higher = faster. Strategy cannot full-scan every bar (TradingView 20s cap).")
minMatchEndOffset = input.int(0, "Min match end (bars ago)", minval = 0, maxval = 500, tooltip = "0 = auto (pattern length + 4). Decouples analogue search from Forecast Bars length.")
recomputeEveryBars = input.int(15, "Recompute analogue every N bars", minval = 1, maxval = 200, tooltip = "Full search runs only this often. Same match + cone stay sticky in between (stable signals, fast backtests).")
alsoRecomputeNewDay = input.bool(true, "Also recompute on new calendar day")
topK = input.int(5, "Top Matches", minval = 1, maxval = 8)
minConfidence = input.float(65.0, "Min Confidence", minval = 0.0, maxval = 100.0, step = 1.0)

strategyMode = input.string("momentum", "Strategy Mode", options = ["momentum", "mean_reversion", "breakout"])
forecastThreshold = input.float(0.02, "Forecast Threshold", minval = 0.001, maxval = 0.20, step = 0.001)

scale1 = input.float(0.75, "Scale 1", minval = 0.50, maxval = 2.50, step = 0.05)
scale2 = input.float(1.00, "Scale 2", minval = 0.50, maxval = 2.50, step = 0.05)
scale3 = input.float(1.25, "Scale 3", minval = 0.50, maxval = 2.50, step = 0.05)
scale4 = input.float(1.50, "Scale 4", minval = 0.50, maxval = 2.50, step = 0.05)

wCorrelation = input.float(0.45, "Weight · Correlation", minval = 0.0, maxval = 1.0, step = 0.05)
wDistance = input.float(0.30, "Weight · Distance", minval = 0.0, maxval = 1.0, step = 0.05)
wDirection = input.float(0.15, "Weight · Direction", minval = 0.0, maxval = 1.0, step = 0.05)
wVolatility = input.float(0.10, "Weight · Volatility", minval = 0.0, maxval = 1.0, step = 0.05)

trendThreshold = input.float(0.02, "Trend Threshold", minval = 0.001, maxval = 0.20, step = 0.001)
volatilityThreshold = input.float(0.020, "High Vol Threshold", minval = 0.001, maxval = 0.10, step = 0.001)
meanReversionTurnPct = input.float(0.55, "Mean-Reversion Turn Ratio", minval = 0.10, maxval = 0.90, step = 0.05)

f_sum_float_array(array<float> values) =>
    total = 0.0
    for i = 0 to array.size(values) - 1
        total += array.get(values, i)
    total

f_mean(array<float> values) =>
    count = array.size(values)
    count == 0 ? 0.0 : f_sum_float_array(values) / count

f_std(array<float> values) =>
    count = array.size(values)
    if count <= 1
        0.0
    else
        avg = f_mean(values)
        variance = 0.0
        for i = 0 to count - 1
            diff = array.get(values, i) - avg
            variance += diff * diff
        math.sqrt(variance / count)

f_sample_price(int endOffset, int candidateLength, int sampleCount, int sampleIndex) =>
    denominator = math.max(sampleCount - 1, 1)
    samplePosition = sampleCount == 1 ? 0 : int(math.round(sampleIndex * (candidateLength - 1) / denominator))
    close[endOffset + candidateLength - 1 - samplePosition]

f_fill_sampled_prices(array<float> out, int endOffset, int candidateLength, int sampleCount) =>
    array.clear(out)
    for i = 0 to sampleCount - 1
        array.push(out, f_sample_price(endOffset, candidateLength, sampleCount, i))

f_fill_log_returns(array<float> prices, array<float> out) =>
    array.clear(out)
    priceCount = array.size(prices)
    if priceCount > 1
        for i = 1 to priceCount - 1
            prev = math.max(array.get(prices, i - 1), 0.0000001)
            curr = math.max(array.get(prices, i), 0.0000001)
            array.push(out, math.log(curr / prev))

f_zscore(array<float> source) =>
    normalized = array.new_float()
    avg = f_mean(source)
    stdev = f_std(source)
    for i = 0 to array.size(source) - 1
        value = array.get(source, i)
        array.push(normalized, stdev == 0.0 ? 0.0 : (value - avg) / stdev)
    normalized

f_correlation(array<float> a, array<float> b) =>
    count = math.min(array.size(a), array.size(b))
    if count <= 1
        0.0
    else
        avgA = f_mean(a)
        avgB = f_mean(b)
        numerator = 0.0
        denomA = 0.0
        denomB = 0.0
        for i = 0 to count - 1
            da = array.get(a, i) - avgA
            db = array.get(b, i) - avgB
            numerator += da * db
            denomA += da * da
            denomB += db * db
        denominator = math.sqrt(denomA * denomB)
        denominator == 0.0 ? 0.0 : math.max(-1.0, math.min(1.0, numerator / denominator))

f_mae(array<float> a, array<float> b) =>
    count = math.min(array.size(a), array.size(b))
    if count == 0
        10.0
    else
        errorSum = 0.0
        for i = 0 to count - 1
            errorSum += math.abs(array.get(a, i) - array.get(b, i))
        errorSum / count

f_direction_agreement(array<float> a, array<float> b) =>
    count = math.min(array.size(a), array.size(b))
    if count == 0
        0.0
    else
        aligned = 0.0
        for i = 0 to count - 1
            va = array.get(a, i)
            vb = array.get(b, i)
            sameSide = (va >= 0 and vb >= 0) or (va < 0 and vb < 0)
            aligned += sameSide ? 1.0 : 0.0
        aligned / count

f_regime_code(array<float> prices, array<float> returns, float localTrendThreshold, float highVolThreshold, float turnRatioThreshold) =>
    priceCount = array.size(prices)
    returnCount = array.size(returns)
    if priceCount == 0 or returnCount == 0
        0
    else
        firstPrice = array.get(prices, 0)
        lastPrice = array.get(prices, priceCount - 1)
        totalReturn = firstPrice == 0.0 ? 0.0 : (lastPrice - firstPrice) / firstPrice
        localVol = f_std(returns)
        turnCount = 0.0
        if returnCount > 1
            for i = 1 to returnCount - 1
                prev = array.get(returns, i - 1)
                curr = array.get(returns, i)
                turned = (prev >= 0 and curr < 0) or (prev < 0 and curr >= 0)
                turnCount += turned ? 1.0 : 0.0
        turnRatio = returnCount <= 1 ? 0.0 : turnCount / (returnCount - 1)
        regime = 0
        if localVol >= highVolThreshold
            regime := 2
        else if totalReturn >= localTrendThreshold
            regime := 1
        else if totalReturn <= -localTrendThreshold
            regime := -1
        else if turnRatio >= turnRatioThreshold
            regime := 0
        regime

f_regime_label(int regimeCode) =>
    regimeCode == 2 ? "high_vol" : regimeCode == 1 ? "trending_up" : regimeCode == -1 ? "trending_down" : "mean_reverting"

f_score_candidate(
    array<float> queryReturns,
    array<float> queryNorm,
    float queryVol,
    int endOffset,
    int candidateLength,
    int sampleCount,
    float wc,
    float wd,
    float wdir,
    float wvol,
    float localTrendThreshold,
    float highVolThreshold,
    float turnRatioThreshold
) =>
    candidatePrices = array.new_float()
    candidateReturns = array.new_float()
    f_fill_sampled_prices(candidatePrices, endOffset, candidateLength, sampleCount)
    f_fill_log_returns(candidatePrices, candidateReturns)
    candidateNorm = f_zscore(candidateReturns)

    corrScore = (f_correlation(queryNorm, candidateNorm) + 1.0) * 0.5
    distScore = 1.0 / (1.0 + f_mae(queryNorm, candidateNorm))
    dirScore = f_direction_agreement(queryReturns, candidateReturns)
    candidateVol = f_std(candidateReturns)
    volScore = 1.0 / (1.0 + math.abs(queryVol - candidateVol) / math.max(queryVol, 0.000001))

    weightSum = math.max(wc + wd + wdir + wvol, 0.0001)
    confidence = 100.0 * (wc * corrScore + wd * distScore + wdir * dirScore + wvol * volScore) / weightSum
    regimeCode = f_regime_code(candidatePrices, candidateReturns, localTrendThreshold, highVolThreshold, turnRatioThreshold)
    [confidence, regimeCode]

f_insert_top_match(
    array<float> scores,
    array<int> endOffsets,
    array<int> lengths,
    array<float> scales,
    array<int> regimes,
    float score,
    int endOffset,
    int candidateLength,
    float scaleValue,
    int regimeCode,
    int maxMatches
) =>
    inserted = false
    currentCount = array.size(scores)
    if currentCount == 0
        array.push(scores, score)
        array.push(endOffsets, endOffset)
        array.push(lengths, candidateLength)
        array.push(scales, scaleValue)
        array.push(regimes, regimeCode)
        inserted := true
    else
        for i = 0 to currentCount - 1
            if not inserted and score > array.get(scores, i)
                array.insert(scores, i, score)
                array.insert(endOffsets, i, endOffset)
                array.insert(lengths, i, candidateLength)
                array.insert(scales, i, scaleValue)
                array.insert(regimes, i, regimeCode)
                inserted := true
    if not inserted and currentCount < maxMatches
        array.push(scores, score)
        array.push(endOffsets, endOffset)
        array.push(lengths, candidateLength)
        array.push(scales, scaleValue)
        array.push(regimes, regimeCode)
    while array.size(scores) > maxMatches
        array.pop(scores)
        array.pop(endOffsets)
        array.pop(lengths)
        array.pop(scales)
        array.pop(regimes)

searchMinEndOffset = minMatchEndOffset > 0 ? minMatchEndOffset : patternLength + 4
enoughHistory = bar_index > searchLookback + patternLength + math.max(forecastBars, searchMinEndOffset)

var array<float> topScores = array.new_float()
var array<int> topEndOffsets = array.new_int()
var array<int> topLengths = array.new_int()
var array<float> topScales = array.new_float()
var array<int> topRegimes = array.new_int()

var int lastSearchBarIndex = na
var float persistBestScore = na
var float persistBestScale = na
var int persistRegimeCode = 0
// Forward path of the #1 (best) analogue only: cumulative returns from its match anchor.
var float persistBestTermRet = na
var float persistBestMinRet = na
var float persistBestMaxRet = na

float bestScore = na
float bestScale = na
int bestRegimeCode = 0
float bestTermRet = na
float bestMinRet = na
float bestMaxRet = na

newTradingDay = ta.change(time("D")) != 0
needFullSearch = enoughHistory and (na(lastSearchBarIndex) or (bar_index - lastSearchBarIndex >= recomputeEveryBars) or (alsoRecomputeNewDay and newTradingDay))

if needFullSearch
    lastSearchBarIndex := bar_index
    array.clear(topScores)
    array.clear(topEndOffsets)
    array.clear(topLengths)
    array.clear(topScales)
    array.clear(topRegimes)

    queryPrices = array.new_float()
    queryReturns = array.new_float()
    f_fill_sampled_prices(queryPrices, 0, patternLength, patternLength)
    f_fill_log_returns(queryPrices, queryReturns)
    queryNorm = f_zscore(queryReturns)
    queryVol = f_std(queryReturns)

    scales = array.new_float()
    array.push(scales, scale1)
    array.push(scales, scale2)
    array.push(scales, scale3)
    array.push(scales, scale4)

    for scaleIndex = 0 to array.size(scales) - 1
        scaleValue = array.get(scales, scaleIndex)
        candidateLength = int(math.max(2, math.round(patternLength * scaleValue)))
        maxEndOffset = searchLookback - candidateLength + 1
        if maxEndOffset >= searchMinEndOffset
            for endOffset = searchMinEndOffset to maxEndOffset by searchStride
                [candidateScore, candidateRegime] = f_score_candidate(
                     queryReturns,
                     queryNorm,
                     queryVol,
                     endOffset,
                     candidateLength,
                     patternLength,
                     wCorrelation,
                     wDistance,
                     wDirection,
                     wVolatility,
                     trendThreshold,
                     volatilityThreshold,
                     meanReversionTurnPct)
                if candidateScore >= minConfidence
                    f_insert_top_match(topScores, topEndOffsets, topLengths, topScales, topRegimes, candidateScore, endOffset, candidateLength, scaleValue, candidateRegime, topK)

    if array.size(topScores) > 0
        persistBestScore := array.get(topScores, 0)
        persistBestScale := array.get(topScales, 0)
        persistRegimeCode := array.get(topRegimes, 0)

        bestEnd = array.get(topEndOffsets, 0)
        matchAnchor = close[bestEnd]
        pathMinRet = na
        pathMaxRet = na
        termRet = na
        for step = 1 to forecastBars
            if bestEnd >= step and matchAnchor != 0.0
                futurePrice = close[bestEnd - step]
                r = (futurePrice - matchAnchor) / matchAnchor
                pathMinRet := na(pathMinRet) ? r : math.min(pathMinRet, r)
                pathMaxRet := na(pathMaxRet) ? r : math.max(pathMaxRet, r)
                if step == forecastBars
                    termRet := r

        persistBestTermRet := termRet
        persistBestMinRet := pathMinRet
        persistBestMaxRet := pathMaxRet
    else
        persistBestScore := na
        persistBestScale := na
        persistRegimeCode := 0
        persistBestTermRet := na
        persistBestMinRet := na
        persistBestMaxRet := na

if enoughHistory
    bestScore := persistBestScore
    bestScale := persistBestScale
    bestRegimeCode := persistRegimeCode
    bestTermRet := persistBestTermRet
    bestMinRet := persistBestMinRet
    bestMaxRet := persistBestMaxRet

regimeIsUp = bestRegimeCode == 1
regimeIsDown = bestRegimeCode == -1
regimeIsMeanReverting = bestRegimeCode == 0
regimeIsHighVol = bestRegimeCode == 2

pathRange = not na(bestMaxRet) and not na(bestMinRet) ? bestMaxRet - bestMinRet : na

longSignal = false
shortSignal = false

if enoughHistory and not na(bestScore) and not na(bestTermRet)
    if strategyMode == "momentum"
        longSignal := bestScore >= minConfidence and regimeIsUp and bestTermRet > forecastThreshold
        shortSignal := bestScore >= minConfidence and regimeIsDown and bestTermRet < -forecastThreshold
    else if strategyMode == "mean_reversion"
        longSignal := bestScore >= minConfidence and regimeIsMeanReverting and not na(pathRange) and pathRange > forecastThreshold and bestTermRet < -forecastThreshold
        shortSignal := bestScore >= minConfidence and regimeIsMeanReverting and not na(pathRange) and pathRange > forecastThreshold and bestTermRet > forecastThreshold
    else
        longSignal := bestScore >= minConfidence and regimeIsHighVol and not na(bestMaxRet) and bestMaxRet > forecastThreshold
        shortSignal := bestScore >= minConfidence and regimeIsHighVol and not na(bestMinRet) and bestMinRet < -forecastThreshold

longStop = not na(bestMinRet) ? close * (1.0 + bestMinRet) : na
longTarget = not na(bestTermRet) and bestTermRet > 0 ? close * (1.0 + bestTermRet) : na
shortStop = not na(bestMaxRet) ? close * (1.0 + bestMaxRet) : na
shortTarget = not na(bestTermRet) and bestTermRet < 0 ? close * (1.0 + bestTermRet) : na

if longSignal and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)

if shortSignal and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)

if strategy.position_size > 0 and not na(longStop)
    if not na(longTarget)
        strategy.exit("Long Exit", "Long", stop = longStop, limit = longTarget)
    else
        strategy.exit("Long Exit", "Long", stop = longStop)

if strategy.position_size < 0 and not na(shortStop)
    if not na(shortTarget)
        strategy.exit("Short Exit", "Short", stop = shortStop, limit = shortTarget)
    else
        strategy.exit("Short Exit", "Short", stop = shortStop)

plot(not na(bestScore) ? bestScore : na, "Confidence", color = color.new(color.lime, 0), linewidth = 2)
plot(not na(bestTermRet) ? bestTermRet * 100.0 : na, "Best analogue terminal %", color = color.new(color.aqua, 0), linewidth = 2)
plotshape(longSignal, title = "Long Signal", style = shape.triangleup, location = location.belowbar, color = color.new(color.lime, 0), size = size.tiny, text = "SIM LONG")
plotshape(shortSignal, title = "Short Signal", style = shape.triangledown, location = location.abovebar, color = color.new(color.red, 0), size = size.tiny, text = "SIM SHORT")

var label regimeLabel = na
if barstate.islast
    if not na(regimeLabel)
        label.delete(regimeLabel)
    regimeText = enoughHistory and not na(bestScore) ? "Similarity " + strategyMode + "\nRegime: " + f_regime_label(bestRegimeCode) + "\nConfidence: " + str.tostring(bestScore, "#.0") + "\nScale: " + str.tostring(bestScale, "#.00") + "x\nBest path terminal: " + (na(bestTermRet) ? "n/a" : str.tostring(bestTermRet * 100.0, "#.00") + "%") : "Similarity strategy warming up"
    regimeLabel := label.new(bar_index, high, regimeText, style = label.style_label_left, textcolor = color.white, color = color.new(color.black, 35))
