//@version=6
// Risk/realism: sized for survival, not curve-fit "alpha". No edge is guaranteed—walk-forward and paper trade before live.
strategy("The Similarity Strategy", overlay = true, pyramiding = 0, max_bars_back = 5000, initial_capital = 100000, default_qty_type = strategy.percent_of_equity, default_qty_value = 5, commission_type = strategy.commission.percent, commission_value = 0.05, slippage = 3, process_orders_on_close = true)

gBot = "Bot — risk & exits"
gFilt = "Bot — filters"

useAtrStopPad = input.bool(true, "Widen stops with ATR pad", group = gBot, tooltip = "If the path stop is tighter than ATR×multiplier from entry, use the wider (safer) stop.")
atrLen = input.int(14, "ATR length", minval = 1, maxval = 100, group = gBot)
atrStopMult = input.float(1.75, "ATR × for stop pad", minval = 0.25, maxval = 6.0, step = 0.05, group = gBot)
minStopDistancePct = input.float(0.35, "Min stop distance % (widen tight path stops)", minval = 0.05, maxval = 5.0, step = 0.05, group = gBot)
maxAdverseStopPct = input.float(12.0, "Cap max stop distance % (tighten absurdly wide path stops)", minval = 1.0, maxval = 50.0, step = 0.5, group = gBot)
maxBarsInTrade = input.int(72, "Max bars in trade (0 = off)", minval = 0, maxval = 500, group = gBot, tooltip = "~36h on 30m; avoids aging a thesis.")
minBarsBetweenTrades = input.int(0, "Min bars between new entries", minval = 0, maxval = 100, group = gBot, tooltip = "Raise to throttle; 0 = no artificial gap between entries.")

useHigherTfTrend = input.bool(false, "Higher-TF MA filter", group = gFilt, tooltip = "OFF by default: similarity vote is not blocked by HTF MA (denser trades). Turn ON to only long above / short below HTF SMA.")
higherTf = input.timeframe("240", "Higher timeframe", group = gFilt)
higherTfMALen = input.int(34, "HTF SMA length", minval = 5, maxval = 200, group = gFilt)

useSessionGate = input.bool(false, "Trade only in session", group = gFilt)
tradeSession = input.session("0000-2359", "Session (exchange tz)", group = gFilt)

patternLength = input.int(40, "Pattern Length", minval = 20, maxval = 120)
forecastBars = input.int(20, "Forecast Bars", minval = 5, maxval = 60)
searchLookback = input.int(600, "Search Lookback", minval = 200, maxval = 3000)
searchStride = input.int(3, "Search Stride", minval = 1, maxval = 15, tooltip = "Lower = denser scan, more analogue hits, slower backtest (TV 20s cap).")
minMatchEndOffset = input.int(0, "Min match end (bars ago)", minval = 0, maxval = 500, tooltip = "0 = auto (pattern length + 4). Decouples analogue search from Forecast Bars length.")
recomputeEveryBars = input.int(6, "Recompute analogue every N bars", minval = 1, maxval = 200, tooltip = "Lower = refresh best match more often → setups can flip sooner, less dead air between narratives.")
alsoRecomputeNewDay = input.bool(true, "Also recompute on new calendar day")
entryOnNewSignalOnly = input.bool(true, "Enter on new signal only", tooltip = "Strongly recommended ON. Sticky thesis keeps longSignal true many bars; without this you re-enter immediately after every exit → trade clusters. OFF = legacy (enter every bar while flat + signal).")
reenterAfterExit = input.bool(true, "Re-enter bar after exit if setup still on", tooltip = "When pulse-only entries would lock out for long stretches because the sticky signal never flickers off.")
enterOnlyAfterRecompute = input.bool(false, "Also require fresh analogue this bar", tooltip = "If ON, only take entries on bars where the full search ran. Fewer trades; can skip moves between refreshes.")
topK = input.int(5, "Top Matches", minval = 1, maxval = 8)
minConfidenceSearch = input.float(45.0, "Min confidence for search basket", minval = 0.0, maxval = 100.0, step = 1.0, tooltip = "Candidates ≥ this enter top-K / cone. Set LOWER than trade min so a dull stretch does not zero out persist for months (no analogues → no P50).")
minConfidence = input.float(52.0, "Min confidence to trade", minval = 0.0, maxval = 100.0, step = 1.0, tooltip = "Rank-1 score must clear this to open trades. Can stay above search min to filter entries.")
momentumSignalUsesWeightedP50 = input.bool(false, "Momentum: use weighted P50 for entry", tooltip = "OFF (default): entry direction uses #1 match horizon return only — weighted median often sits near 0 for months when analogues disagree. ON: strict cone P50 (closer to Python momentum_strategy). Exits always use full weighted cone.")

strategyMode = input.string("momentum", "Strategy Mode", options = ["momentum", "mean_reversion", "breakout"])
strictRegimeForMode = input.bool(false, "Require regime tag vs strategy mode", tooltip = "OFF (default): trade on score + analogue path only—best match often labels mean_reverting/high_vol so strict ON creates long flat spans. ON: legacy—momentum needs trending_up/down on the matched segment, etc.")
forecastThreshold = input.float(0.012, "Forecast Threshold", minval = 0.001, maxval = 0.20, step = 0.001, tooltip = "Momentum: |weighted P50| at horizon vs this. Mean reversion: min spread (P90−P10) and |P50|.")

scale1 = input.float(0.75, "Scale 1", minval = 0.50, maxval = 2.50, step = 0.05)
scale2 = input.float(1.00, "Scale 2", minval = 0.50, maxval = 2.50, step = 0.05)
scale3 = input.float(1.25, "Scale 3", minval = 0.50, maxval = 2.50, step = 0.05)
scale4 = input.float(1.50, "Scale 4", minval = 0.50, maxval = 2.50, step = 0.05)

wCorrelation = input.float(0.45, "Weight · Correlation", minval = 0.0, maxval = 1.0, step = 0.05)
wDistance = input.float(0.30, "Weight · Distance", minval = 0.0, maxval = 1.0, step = 0.05)
wDirection = input.float(0.15, "Weight · Direction", minval = 0.0, maxval = 1.0, step = 0.05)
wVolatility = input.float(0.10, "Weight · Volatility", minval = 0.0, maxval = 1.0, step = 0.05)

trendThreshold = input.float(0.02, "Trend Threshold", minval = 0.001, maxval = 0.20, step = 0.001)
volatilityThreshold = input.float(0.020, "High Vol Threshold", minval = 0.001, maxval = 0.10, step = 0.001)
meanReversionTurnPct = input.float(0.55, "Mean-Reversion Turn Ratio", minval = 0.10, maxval = 0.90, step = 0.05)

f_sum_float_array(array<float> values) =>
    total = 0.0
    for i = 0 to array.size(values) - 1
        total += array.get(values, i)
    total

f_mean(array<float> values) =>
    count = array.size(values)
    count == 0 ? 0.0 : f_sum_float_array(values) / count

f_std(array<float> values) =>
    count = array.size(values)
    if count <= 1
        0.0
    else
        avg = f_mean(values)
        variance = 0.0
        for i = 0 to count - 1
            diff = array.get(values, i) - avg
            variance += diff * diff
        math.sqrt(variance / count)

f_sample_price(int endOffset, int candidateLength, int sampleCount, int sampleIndex) =>
    denominator = math.max(sampleCount - 1, 1)
    samplePosition = sampleCount == 1 ? 0 : int(math.round(sampleIndex * (candidateLength - 1) / denominator))
    close[endOffset + candidateLength - 1 - samplePosition]

f_fill_sampled_prices(array<float> out, int endOffset, int candidateLength, int sampleCount) =>
    array.clear(out)
    for i = 0 to sampleCount - 1
        array.push(out, f_sample_price(endOffset, candidateLength, sampleCount, i))

f_fill_log_returns(array<float> prices, array<float> out) =>
    array.clear(out)
    priceCount = array.size(prices)
    if priceCount > 1
        for i = 1 to priceCount - 1
            prev = math.max(array.get(prices, i - 1), 0.0000001)
            curr = math.max(array.get(prices, i), 0.0000001)
            array.push(out, math.log(curr / prev))

f_zscore(array<float> source) =>
    normalized = array.new_float()
    avg = f_mean(source)
    stdev = f_std(source)
    for i = 0 to array.size(source) - 1
        value = array.get(source, i)
        array.push(normalized, stdev == 0.0 ? 0.0 : (value - avg) / stdev)
    normalized

f_correlation(array<float> a, array<float> b) =>
    count = math.min(array.size(a), array.size(b))
    if count <= 1
        0.0
    else
        avgA = f_mean(a)
        avgB = f_mean(b)
        numerator = 0.0
        denomA = 0.0
        denomB = 0.0
        for i = 0 to count - 1
            da = array.get(a, i) - avgA
            db = array.get(b, i) - avgB
            numerator += da * db
            denomA += da * da
            denomB += db * db
        denominator = math.sqrt(denomA * denomB)
        denominator == 0.0 ? 0.0 : math.max(-1.0, math.min(1.0, numerator / denominator))

f_mae(array<float> a, array<float> b) =>
    count = math.min(array.size(a), array.size(b))
    if count == 0
        10.0
    else
        errorSum = 0.0
        for i = 0 to count - 1
            errorSum += math.abs(array.get(a, i) - array.get(b, i))
        errorSum / count

f_direction_agreement(array<float> a, array<float> b) =>
    count = math.min(array.size(a), array.size(b))
    if count == 0
        0.0
    else
        aligned = 0.0
        for i = 0 to count - 1
            va = array.get(a, i)
            vb = array.get(b, i)
            sameSide = (va >= 0 and vb >= 0) or (va < 0 and vb < 0)
            aligned += sameSide ? 1.0 : 0.0
        aligned / count

f_regime_code(array<float> prices, array<float> returns, float localTrendThreshold, float highVolThreshold, float turnRatioThreshold) =>
    priceCount = array.size(prices)
    returnCount = array.size(returns)
    if priceCount == 0 or returnCount == 0
        0
    else
        firstPrice = array.get(prices, 0)
        lastPrice = array.get(prices, priceCount - 1)
        totalReturn = firstPrice == 0.0 ? 0.0 : (lastPrice - firstPrice) / firstPrice
        localVol = f_std(returns)
        turnCount = 0.0
        if returnCount > 1
            for i = 1 to returnCount - 1
                prev = array.get(returns, i - 1)
                curr = array.get(returns, i)
                turned = (prev >= 0 and curr < 0) or (prev < 0 and curr >= 0)
                turnCount += turned ? 1.0 : 0.0
        turnRatio = returnCount <= 1 ? 0.0 : turnCount / (returnCount - 1)
        regime = 0
        if localVol >= highVolThreshold
            regime := 2
        else if totalReturn >= localTrendThreshold
            regime := 1
        else if totalReturn <= -localTrendThreshold
            regime := -1
        else if turnRatio >= turnRatioThreshold
            regime := 0
        regime

f_regime_label(int regimeCode) =>
    regimeCode == 2 ? "high_vol" : regimeCode == 1 ? "trending_up" : regimeCode == -1 ? "trending_down" : "mean_reverting"

f_score_candidate(
    array<float> queryReturns,
    array<float> queryNorm,
    float queryVol,
    int endOffset,
    int candidateLength,
    int sampleCount,
    float wc,
    float wd,
    float wdir,
    float wvol,
    float localTrendThreshold,
    float highVolThreshold,
    float turnRatioThreshold
) =>
    candidatePrices = array.new_float()
    candidateReturns = array.new_float()
    f_fill_sampled_prices(candidatePrices, endOffset, candidateLength, sampleCount)
    f_fill_log_returns(candidatePrices, candidateReturns)
    candidateNorm = f_zscore(candidateReturns)

    corrScore = (f_correlation(queryNorm, candidateNorm) + 1.0) * 0.5
    distScore = 1.0 / (1.0 + f_mae(queryNorm, candidateNorm))
    dirScore = f_direction_agreement(queryReturns, candidateReturns)
    candidateVol = f_std(candidateReturns)
    volScore = 1.0 / (1.0 + math.abs(queryVol - candidateVol) / math.max(queryVol, 0.000001))

    weightSum = math.max(wc + wd + wdir + wvol, 0.0001)
    confidence = 100.0 * (wc * corrScore + wd * distScore + wdir * dirScore + wvol * volScore) / weightSum
    regimeCode = f_regime_code(candidatePrices, candidateReturns, localTrendThreshold, highVolThreshold, turnRatioThreshold)
    [confidence, regimeCode]

f_insert_top_match(
    array<float> scores,
    array<int> endOffsets,
    array<int> lengths,
    array<float> scales,
    array<int> regimes,
    float score,
    int endOffset,
    int candidateLength,
    float scaleValue,
    int regimeCode,
    int maxMatches
) =>
    inserted = false
    currentCount = array.size(scores)
    if currentCount == 0
        array.push(scores, score)
        array.push(endOffsets, endOffset)
        array.push(lengths, candidateLength)
        array.push(scales, scaleValue)
        array.push(regimes, regimeCode)
        inserted := true
    else
        for i = 0 to currentCount - 1
            if not inserted and score > array.get(scores, i)
                array.insert(scores, i, score)
                array.insert(endOffsets, i, endOffset)
                array.insert(lengths, i, candidateLength)
                array.insert(scales, i, scaleValue)
                array.insert(regimes, i, regimeCode)
                inserted := true
    if not inserted and currentCount < maxMatches
        array.push(scores, score)
        array.push(endOffsets, endOffset)
        array.push(lengths, candidateLength)
        array.push(scales, scaleValue)
        array.push(regimes, regimeCode)
    while array.size(scores) > maxMatches
        array.pop(scores)
        array.pop(endOffsets)
        array.pop(lengths)
        array.pop(scales)
        array.pop(regimes)

// Weighted empirical quantiles over top-K forward paths (matches similarity_indicator + Python project() idea).
f_sort_pairs(array<float> values, array<float> weights) =>
    count = array.size(values)
    if count > 1
        for i = 0 to count - 2
            for j = 0 to count - 2 - i
                left = array.get(values, j)
                right = array.get(values, j + 1)
                if left > right
                    leftWeight = array.get(weights, j)
                    rightWeight = array.get(weights, j + 1)
                    array.set(values, j, right)
                    array.set(values, j + 1, left)
                    array.set(weights, j, rightWeight)
                    array.set(weights, j + 1, leftWeight)

f_weighted_percentile(array<float> rawValues, array<float> rawWeights, float quantile) =>
    sortedValues = array.new_float()
    sortedWeights = array.new_float()
    for i = 0 to array.size(rawValues) - 1
        array.push(sortedValues, array.get(rawValues, i))
        array.push(sortedWeights, array.get(rawWeights, i))
    f_sort_pairs(sortedValues, sortedWeights)
    totalWeight = f_sum_float_array(sortedWeights)
    if totalWeight == 0.0
        array.size(sortedValues) == 0 ? 0.0 : array.get(sortedValues, array.size(sortedValues) - 1)
    else
        cumulative = 0.0
        chosen = array.get(sortedValues, array.size(sortedValues) - 1)
        for i = 0 to array.size(sortedValues) - 1
            cumulative += array.get(sortedWeights, i) / totalWeight
            if cumulative >= quantile
                chosen := array.get(sortedValues, i)
                break
        chosen

searchMinEndOffset = minMatchEndOffset > 0 ? minMatchEndOffset : patternLength + 4
enoughHistory = bar_index > searchLookback + patternLength + math.max(forecastBars, searchMinEndOffset)

var array<float> topScores = array.new_float()
var array<int> topEndOffsets = array.new_int()
var array<int> topLengths = array.new_int()
var array<float> topScales = array.new_float()
var array<int> topRegimes = array.new_int()

var int lastSearchBarIndex = na
var float persistBestScore = na
var float persistBestScale = na
var int persistRegimeCode = 0
// Terminal cumulative returns of weighted percentile cone over top-K (horizon = Forecast Bars).
var float persistP10 = na
var float persistP25 = na
var float persistP50 = na
var float persistP75 = na
var float persistP90 = na
var float persistRank1Horizon = na

// Locked at entry: cone endpoints for exits (Python momentum: long P10 stop / P75 target; short P90 / P25).
var float posP10 = na
var float posP25 = na
var float posP50 = na
var float posP75 = na
var float posP90 = na
var int tradeEntryBar = na
var int lastEntryBarIndex = -2147483648

float bestScore = na
float bestScale = na
int bestRegimeCode = 0
float bestP10 = na
float bestP25 = na
float bestP50 = na
float bestP75 = na
float bestP90 = na
float bestRank1Horizon = na

newTradingDay = ta.change(time("D")) != 0
needFullSearch = enoughHistory and (na(lastSearchBarIndex) or (bar_index - lastSearchBarIndex >= recomputeEveryBars) or (alsoRecomputeNewDay and newTradingDay))

if needFullSearch
    lastSearchBarIndex := bar_index
    array.clear(topScores)
    array.clear(topEndOffsets)
    array.clear(topLengths)
    array.clear(topScales)
    array.clear(topRegimes)

    queryPrices = array.new_float()
    queryReturns = array.new_float()
    f_fill_sampled_prices(queryPrices, 0, patternLength, patternLength)
    f_fill_log_returns(queryPrices, queryReturns)
    queryNorm = f_zscore(queryReturns)
    queryVol = f_std(queryReturns)

    scales = array.new_float()
    array.push(scales, scale1)
    array.push(scales, scale2)
    array.push(scales, scale3)
    array.push(scales, scale4)

    for scaleIndex = 0 to array.size(scales) - 1
        scaleValue = array.get(scales, scaleIndex)
        candidateLength = int(math.max(2, math.round(patternLength * scaleValue)))
        maxEndOffset = searchLookback - candidateLength + 1
        if maxEndOffset >= searchMinEndOffset
            for endOffset = searchMinEndOffset to maxEndOffset by searchStride
                [candidateScore, candidateRegime] = f_score_candidate(
                     queryReturns,
                     queryNorm,
                     queryVol,
                     endOffset,
                     candidateLength,
                     patternLength,
                     wCorrelation,
                     wDistance,
                     wDirection,
                     wVolatility,
                     trendThreshold,
                     volatilityThreshold,
                     meanReversionTurnPct)
                if candidateScore >= minConfidenceSearch
                    f_insert_top_match(topScores, topEndOffsets, topLengths, topScales, topRegimes, candidateScore, endOffset, candidateLength, scaleValue, candidateRegime, topK)

    if array.size(topScores) > 0
        persistBestScore := array.get(topScores, 0)
        persistBestScale := array.get(topScales, 0)
        persistRegimeCode := array.get(topRegimes, 0)

        bestEndR1 = array.get(topEndOffsets, 0)
        anchorR1 = close[bestEndR1]
        persistRank1Horizon := float(na)
        if anchorR1 != 0.0 and bestEndR1 >= forecastBars
            persistRank1Horizon := (close[bestEndR1 - forecastBars] - anchorR1) / anchorR1

        array<float> fcP10 = array.new_float()
        array<float> fcP25 = array.new_float()
        array<float> fcP50 = array.new_float()
        array<float> fcP75 = array.new_float()
        array<float> fcP90 = array.new_float()
        array<float> stepValues = array.new_float()
        array<float> stepWeights = array.new_float()

        for step = 1 to forecastBars
            array.clear(stepValues)
            array.clear(stepWeights)
            for matchIndex = 0 to array.size(topScores) - 1
                matchEndOffset = array.get(topEndOffsets, matchIndex)
                if matchEndOffset >= step
                    matchAnchor = close[matchEndOffset]
                    futurePrice = close[matchEndOffset - step]
                    if matchAnchor != 0.0
                        array.push(stepValues, (futurePrice - matchAnchor) / matchAnchor)
                        array.push(stepWeights, array.get(topScores, matchIndex))
            if array.size(stepValues) > 0
                array.push(fcP10, f_weighted_percentile(stepValues, stepWeights, 0.10))
                array.push(fcP25, f_weighted_percentile(stepValues, stepWeights, 0.25))
                array.push(fcP50, f_weighted_percentile(stepValues, stepWeights, 0.50))
                array.push(fcP75, f_weighted_percentile(stepValues, stepWeights, 0.75))
                array.push(fcP90, f_weighted_percentile(stepValues, stepWeights, 0.90))
            else
                array.push(fcP10, na)
                array.push(fcP25, na)
                array.push(fcP50, na)
                array.push(fcP75, na)
                array.push(fcP90, na)

        if array.size(fcP50) > 0
            persistP10 := array.get(fcP10, array.size(fcP10) - 1)
            persistP25 := array.get(fcP25, array.size(fcP25) - 1)
            persistP50 := array.get(fcP50, array.size(fcP50) - 1)
            persistP75 := array.get(fcP75, array.size(fcP75) - 1)
            persistP90 := array.get(fcP90, array.size(fcP90) - 1)
        else
            persistP10 := na
            persistP25 := na
            persistP50 := na
            persistP75 := na
            persistP90 := na
            persistRank1Horizon := na
    else
        persistBestScore := na
        persistBestScale := na
        persistRegimeCode := 0
        persistP10 := na
        persistP25 := na
        persistP50 := na
        persistP75 := na
        persistP90 := na
        persistRank1Horizon := na

if enoughHistory
    bestScore := persistBestScore
    bestScale := persistBestScale
    bestRegimeCode := persistRegimeCode
    bestP10 := persistP10
    bestP25 := persistP25
    bestP50 := persistP50
    bestP75 := persistP75
    bestP90 := persistP90
    bestRank1Horizon := persistRank1Horizon

regimeIsUp = bestRegimeCode == 1
regimeIsDown = bestRegimeCode == -1
regimeIsMeanReverting = bestRegimeCode == 0
regimeIsHighVol = bestRegimeCode == 2

coneSpread = not na(bestP90) and not na(bestP10) ? bestP90 - bestP10 : na

longSignal = false
shortSignal = false

if enoughHistory and not na(bestScore)
    if strategyMode == "momentum"
        momRef = momentumSignalUsesWeightedP50 ? bestP50 : bestRank1Horizon
        if not na(momRef)
            momLong = bestScore >= minConfidence and momRef > forecastThreshold
            momShort = bestScore >= minConfidence and momRef < -forecastThreshold
            longSignal := momLong and (strictRegimeForMode ? regimeIsUp : true)
            shortSignal := momShort and (strictRegimeForMode ? regimeIsDown : true)
    else if strategyMode == "mean_reversion"
        if not na(bestP50)
            // Python mean_reversion_strategy: wide P90-P10 spread, fade P50.
            mrLong = bestScore >= minConfidence and not na(coneSpread) and coneSpread > forecastThreshold and bestP50 < -forecastThreshold
            mrShort = bestScore >= minConfidence and not na(coneSpread) and coneSpread > forecastThreshold and bestP50 > forecastThreshold
            longSignal := mrLong and (strictRegimeForMode ? regimeIsMeanReverting : true)
            shortSignal := mrShort and (strictRegimeForMode ? regimeIsMeanReverting : true)
    else
        // Python breakout_strategy: high vol + bullish/bearish upper or lower quantile.
        brLong = bestScore >= minConfidence and not na(bestP75) and bestP75 > 0
        brShort = bestScore >= minConfidence and not na(bestP25) and bestP25 < 0
        longSignal := brLong and (strictRegimeForMode ? regimeIsHighVol : true)
        shortSignal := brShort and (strictRegimeForMode ? regimeIsHighVol : true)

// Pulse = signal just turned on (off → on). reenterAfterExit = first flat bar after a fill while sticky signal stays valid.
longPulse = longSignal and (bar_index == 0 or not longSignal[1])
shortPulse = shortSignal and (bar_index == 0 or not shortSignal[1])
prevPos = nz(strategy.position_size[1], 0)
justOutLong = strategy.position_size <= 0 and prevPos > 0
justOutShort = strategy.position_size >= 0 and prevPos < 0
longRearm = reenterAfterExit and justOutLong and longSignal
shortRearm = reenterAfterExit and justOutShort and shortSignal
longOk = entryOnNewSignalOnly ? (longPulse or longRearm) : longSignal
shortOk = entryOnNewSignalOnly ? (shortPulse or shortRearm) : shortSignal
recomputeThisBar = needFullSearch

htfClose = request.security(syminfo.tickerid, higherTf, close, gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
htfMa = request.security(syminfo.tickerid, higherTf, ta.sma(close, higherTfMALen), gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
htfAlignLong = not useHigherTfTrend or htfClose > htfMa
htfAlignShort = not useHigherTfTrend or htfClose < htfMa
inSession = not useSessionGate or not na(time(timeframe.period, tradeSession, syminfo.timezone))
cooldownOk = minBarsBetweenTrades <= 0 or bar_index - lastEntryBarIndex >= minBarsBetweenTrades

longEntryRaw = longOk and strategy.position_size <= 0 and (not enterOnlyAfterRecompute or recomputeThisBar) and htfAlignLong and inSession and cooldownOk
shortEntryRaw = shortOk and strategy.position_size >= 0 and (not enterOnlyAfterRecompute or recomputeThisBar) and htfAlignShort and inSession and cooldownOk

if longEntryRaw
    posP10 := bestP10
    posP25 := bestP25
    posP50 := bestP50
    posP75 := bestP75
    posP90 := bestP90
    tradeEntryBar := bar_index
    lastEntryBarIndex := bar_index

if shortEntryRaw
    posP10 := bestP10
    posP25 := bestP25
    posP50 := bestP50
    posP75 := bestP75
    posP90 := bestP90
    tradeEntryBar := bar_index
    lastEntryBarIndex := bar_index

if strategy.position_size == 0 and not longEntryRaw and not shortEntryRaw
    posP10 := na
    posP25 := na
    posP50 := na
    posP75 := na
    posP90 := na
    tradeEntryBar := na

longEntry = longEntryRaw
shortEntry = shortEntryRaw

if longEntry
    strategy.entry("Long", strategy.long)

if shortEntry
    strategy.entry("Short", strategy.short)

avgPx = strategy.position_avg_price
minStopFrac = minStopDistancePct / 100.0
maxAdvFrac = maxAdverseStopPct / 100.0
atrRaw = ta.atr(atrLen)
barsInPos = strategy.position_size != 0 and not na(tradeEntryBar) ? bar_index - tradeEntryBar : 0
timeStopHit = maxBarsInTrade > 0 and barsInPos >= maxBarsInTrade and strategy.position_size != 0

// Stops/targets from frozen cone @ avg entry (parity with the_similarity/core/strategy.py _compute_stop / _compute_target).
longStopLvl = strategy.position_size > 0 and not na(posP10) and avgPx != 0 ? avgPx * (1.0 + posP10) : na
longLimitLvl = strategy.position_size > 0 and not na(posP75) and avgPx != 0 ? avgPx * (1.0 + posP75) : na
shortStopLvl = strategy.position_size < 0 and not na(posP90) and avgPx != 0 ? avgPx * (1.0 + posP90) : na
shortLimitLvl = strategy.position_size < 0 and not na(posP25) and avgPx != 0 ? avgPx * (1.0 + posP25) : na

longStopWide = not na(longStopLvl) ? math.min(longStopLvl, avgPx * (1.0 - minStopFrac)) : na
longStopFinal = not na(longStopWide) ? math.max(longStopWide, avgPx * (1.0 - maxAdvFrac)) : na
shortStopWide = not na(shortStopLvl) ? math.max(shortStopLvl, avgPx * (1.0 + minStopFrac)) : na
shortStopFinal = not na(shortStopWide) ? math.min(shortStopWide, avgPx * (1.0 + maxAdvFrac)) : na

longStopPad = useAtrStopPad and not na(longStopFinal) and not na(atrRaw) ? math.min(longStopFinal, avgPx - atrRaw * atrStopMult) : longStopFinal
shortStopPad = useAtrStopPad and not na(shortStopFinal) and not na(atrRaw) ? math.max(shortStopFinal, avgPx + atrRaw * atrStopMult) : shortStopFinal

if strategy.position_size > 0 and not timeStopHit and not na(longStopPad)
    if not na(longLimitLvl)
        strategy.exit("Long Exit", "Long", stop = longStopPad, limit = longLimitLvl)
    else
        strategy.exit("Long Exit", "Long", stop = longStopPad)

if strategy.position_size < 0 and not timeStopHit and not na(shortStopPad)
    if not na(shortLimitLvl)
        strategy.exit("Short Exit", "Short", stop = shortStopPad, limit = shortLimitLvl)
    else
        strategy.exit("Short Exit", "Short", stop = shortStopPad)

if timeStopHit and strategy.position_size > 0
    strategy.close("Long", comment = "Time stop")

if timeStopHit and strategy.position_size < 0
    strategy.close("Short", comment = "Time stop")

// Never plot 0–100 "confidence" on the price pane — it shares the price scale and wrecks Y-axis (lines glued to bottom).
plot(not na(bestScore) ? bestScore : na, "Confidence", color = color.new(color.lime, 0), linewidth = 2, display = display.data_window)
plot(not na(bestP50) ? bestP50 * 100.0 : na, "Weighted P50 terminal %", color = color.new(color.aqua, 0), linewidth = 2, display = display.data_window)
plot(not na(bestRank1Horizon) ? bestRank1Horizon * 100.0 : na, "#1 match horizon %", color = color.new(color.orange, 0), linewidth = 1, display = display.data_window)
plotshape(longSignal, title = "Long setup (sticky)", style = shape.circle, location = location.bottom, color = color.new(color.lime, 85), size = size.tiny, display = display.none)
plotshape(longEntry, title = "Long entry", style = shape.triangleup, location = location.belowbar, color = color.new(color.lime, 0), size = size.tiny, text = "SIM LONG")
plotshape(shortEntry, title = "Short entry", style = shape.triangledown, location = location.abovebar, color = color.new(color.red, 0), size = size.tiny, text = "SIM SHORT")

var label regimeLabel = na
if barstate.islast
    if not na(regimeLabel)
        label.delete(regimeLabel)
    regimeText = enoughHistory and not na(bestScore) ? "Similarity " + strategyMode + "\nRegime: " + f_regime_label(bestRegimeCode) + "\nScore (rank1): " + str.tostring(bestScore, "#.0") + " · trade≥" + str.tostring(minConfidence, "#.0") + " search≥" + str.tostring(minConfidenceSearch, "#.0") + "\nScale: " + str.tostring(bestScale, "#.00") + "x\nP50: " + (na(bestP50) ? "n/a" : str.tostring(bestP50 * 100.0, "#.00") + "%") + " · #1Δ: " + (na(bestRank1Horizon) ? "n/a" : str.tostring(bestRank1Horizon * 100.0, "#.00") + "%") + "\nCone P10/P75 (L exit): " + (na(bestP10) or na(bestP75) ? "n/a" : str.tostring(bestP10 * 100.0, "#.00") + "% / " + str.tostring(bestP75 * 100.0, "#.00") + "%") : "Similarity strategy warming up"
    regimeLabel := label.new(bar_index, high, regimeText, style = label.style_label_left, textcolor = color.white, color = color.new(color.black, 35))
